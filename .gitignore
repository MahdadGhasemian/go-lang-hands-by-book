# Go binary files
/bin/
/obj/

# Dependency directories
/vendor/

# Build output
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Go workspace
/go.work

# IDE specific files
.idea/
.vscode/

# MacOS system files
.DS_Store

# Linux system files
*.swp
*~

